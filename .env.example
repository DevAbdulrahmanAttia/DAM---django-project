# Copy this file to `.env` in the project root and fill in your values.
# Never commit `.env` — it is already in .gitignore.

# Gmail SMTP (required for verification + OTP emails)
# Copy `.env.example` to `.env` — no quotes around the app password value.
EMAIL_HOST_USER=your.email@gmail.com
EMAIL_HOST_PASSWORD=your_16_char_app_password

# Optional: use console backend during local dev (prints emails in terminal)
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
