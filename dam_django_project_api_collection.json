  "item": [
    {
      "name": "Authentication & Accounts",
      "item": [
        {
          "name": "Obtain JWT Token (Login)",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"customer_username\",\n  \"password\": \"customer_password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/token/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token",
                ""
              ]
            },
            "description": "Obtain JWT access and refresh tokens."
          },
          "response": []
        },
        {
          "name": "Refresh JWT Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/token/refresh/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token",
                "refresh",
                ""
              ]
            },
            "description": "Refresh the JWT access token."
          },
          "response": []
        },
        {
          "name": "Verify JWT Token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/token/verify/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "token",
                "verify",
                ""
              ]
            },
            "description": "Verify the JWT access token."
          },
          "response": []
        },
