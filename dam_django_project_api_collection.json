              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/accounts/verify-email/{{uidb64}}/{{email_token}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "verify-email",
                "{{uidb64}}",
                "{{email_token}}",
                ""
              ]
            },
            "description": "Verify user email using base64 encoded UID and email token."
          },
          "response": []
